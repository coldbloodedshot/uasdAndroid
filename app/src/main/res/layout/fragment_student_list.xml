<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/evaluationHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:background="#FAFAFA"
            android:elevation="4dp">

            <Spinner
                android:id="@+id/spinnerEvaluaciones"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="4dp"
                android:background="#DDDDDD"
                android:layout_marginHorizontal="8dp"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar..."
                    android:inputType="text"
                    android:padding="8dp"
                    android:paddingEnd="32dp"
                    android:background="@android:drawable/edit_text"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="4dp"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:visibility="gone"
                    android:contentDescription="Limpiar búsqueda" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnToggleOrden"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:visibility="gone"
                android:contentDescription="Ordenar por fecha de captura" />

            <ImageButton
                android:id="@+id/btnDictado"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_mic"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Iniciar dictado" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewStudents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="150dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- Speed Dial Container -->
    <LinearLayout
        android:id="@+id/fabMenuContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_above="@+id/fabMain"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:elevation="6dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Opción: Asistencia -->
        <LinearLayout
            android:id="@+id/fabActionAttendance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="4dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asistencia"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAttendance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_fact_check"
                app:fabSize="mini"
                android:contentDescription="Asistencia"/>
        </LinearLayout>

        <!-- Opción: Nueva Evaluación -->
        <LinearLayout
            android:id="@+id/fabActionNewEval"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="4dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nueva Evaluación"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabNewEval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_assignment_add"
                app:fabSize="mini"
                android:contentDescription="Nueva Evaluación"/>
        </LinearLayout>

        <!-- Opción: Puntos Extra -->
        <LinearLayout
            android:id="@+id/fabActionExtra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="4dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Puntos Extra"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabExtraPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_stars"
                app:fabSize="mini"
                android:contentDescription="Puntos Extra"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Botón Principal -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        app:fabSize="normal"
        android:contentDescription="Acciones"/>

</RelativeLayout>
